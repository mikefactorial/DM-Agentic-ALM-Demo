{
  "$comment": "Per-environment values for Dataverse environment variables. Key = schema name of the environment variable, Value = { environment-slug: value }. Updated when new environment variables are added to solutions.",
  "$schema": {
    "SchemaName_of_EnvironmentVariable": {
      "env-slug": "value"
    }
  },
  "environments": {
    "dmi-test": {
      "dmi_AzureOpenAIDeployment": "<unset>",
      "dmi_AzureOpenAIEndpoint": "<unset>",
      "dmi_FirstContactPromptTemplate": "<unset>",
      "PD_MANAGEDIDENTITY_dmi-openai-identity": "<unset>"
    },
    "dmi-prod": {
      "dmi_AzureOpenAIDeployment": "<unset>",
      "dmi_AzureOpenAIEndpoint": "<unset>",
      "dmi_FirstContactPromptTemplate": "<unset>",
      "PD_MANAGEDIDENTITY_dmi-openai-identity": "<unset>"
    }
  },
  "metadata": {
    "dmi_AzureOpenAIDeployment": {
      "displayName": "Azure OpenAI Deployment Name",
      "schemaName": "dmi_AzureOpenAIDeployment",
      "type": "String",
      "defaultValue": "gpt-4o",
      "description": ""
    },
    "dmi_AzureOpenAIEndpoint": {
      "displayName": "Azure OpenAI Endpoint",
      "schemaName": "dmi_AzureOpenAIEndpoint",
      "type": "String",
      "defaultValue": "https://YOUR-OPENAI-RESOURCE.openai.azure.com",
      "description": ""
    },
    "dmi_FirstContactPromptTemplate": {
      "displayName": "First Contact System Prompt Override",
      "schemaName": "dmi_FirstContactPromptTemplate",
      "type": "String",
      "defaultValue": "",
      "description": ""
    },
    "PD_MANAGEDIDENTITY_dmi-openai-identity": {
      "displayName": "Managed Identity: dmi-openai-identity",
      "schemaName": "PD_MANAGEDIDENTITY_dmi-openai-identity",
      "type": "String",
      "defaultValue": "",
      "description": ""
    }
  }
}
